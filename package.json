{
  "name": "edu-evidence",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "dev": "astro dev",
    "build": "astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "check:links": "npx tsx scripts/check-links.ts",
    "check:links:live": "linkinator https://edu-evidence.org --recurse --skip 'mailto:|^#|doi\\.org/10\\.1037|us\\.corwin\\.com'",
    "check:links:source": "npx tsx scripts/check-source-links.ts",
    "check:text": "textlint 'src/content/**/*.md'",
    "check:text:fix": "textlint --fix 'src/content/**/*.md'",
    "check:consistency": "npx tsx scripts/check-consistency.ts",
    "check:stale": "npx tsx scripts/check-stale.ts",
    "check:source-sync": "npx tsx scripts/check-source-sync.ts",
    "check:reader-literacy": "npx tsx scripts/check-reader-literacy.ts",
    "check:sentence-length": "npx tsx scripts/check-sentence-length.ts",
    "check:all": "npm run check && npm run check:text && npm run check:reader-literacy && npm run check:sentence-length && npm run check:consistency && npm run check:links:source && npm run check:links",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "a11y:baseline": "node scripts/a11y-baseline.mjs",
    "links:baseline": "npx tsx scripts/check-links.ts --update-baseline",
    "og:default": "npx tsx scripts/generate-default-og.ts"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.3",
    "astro": "^6.4.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "gray-matter": "^4.0.3",
    "linkinator": "^7.6.1",
    "pagefind": "^1.5.2",
    "rehype-external-links": "^3.0.0",
    "textlint": "^15.7.1",
    "textlint-rule-no-mix-dearu-desumasu": "^6.0.4",
    "textlint-rule-preset-ja-spacing": "^3.0.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0"
  }
}

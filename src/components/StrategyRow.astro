---
interface Props {
  index: number;
  href: string;
  title: string;
  monthsGained: number;
  evidenceStrength: number;
  source: "eef" | "japan";
  subjects: string[];
  grades: string[];
}
const { index, href, title, monthsGained, evidenceStrength, source, subjects, grades } =
  Astro.props;
const num = String(index).padStart(2, "0");
const stars = "★".repeat(evidenceStrength) + "☆".repeat(5 - evidenceStrength);
const sourceLabel = source === "japan" ? "日本研究" : "EEF";
const sourceColor =
  source === "japan"
    ? "text-rose-600 border-rose-600/40"
    : "text-sky-700 border-sky-700/40";

const effectSign = monthsGained > 0 ? "+" : monthsGained === 0 ? "±" : "";
const effectColor =
  monthsGained > 0
    ? "text-[var(--color-accent)]"
    : monthsGained === 0
      ? "text-[var(--color-sub)]"
      : "text-red-600";
---

<a
  href={href}
  data-months={monthsGained}
  data-evidence={evidenceStrength}
  class="group block border-t border-[var(--color-line)] py-8 md:py-10 transition hover:bg-[var(--color-card)]"
>
  <div class="grid grid-cols-12 gap-4 md:gap-6 items-center px-2">
    <div
      class="col-span-2 md:col-span-1 font-mono text-sm text-[var(--color-sub)]"
      data-num
    >
      {num}
    </div>

    <div class="col-span-10 md:col-span-7">
      <div class="flex flex-wrap items-center gap-3 mb-1">
        <h3
          class="text-2xl md:text-3xl font-black tracking-tight leading-tight group-hover:text-[var(--color-accent)] transition"
        >
          {title}
        </h3>
        <span
          class={`font-mono text-[10px] tracking-widest uppercase border rounded-full px-2 py-0.5 leading-none inline-flex items-center h-5 ${sourceColor}`}
        >
          {sourceLabel}
        </span>
      </div>
      <div
        class="mt-2 font-mono text-[11px] uppercase tracking-widest text-[var(--color-sub)] flex flex-wrap gap-x-4 gap-y-1"
      >
        <span>{subjects.join(" · ")}</span>
        <span>{grades.join(" · ")}</span>
        <span class="text-amber-600">{stars}</span>
      </div>
    </div>

    <div
      class={`col-span-10 col-start-3 md:col-span-4 md:col-start-auto md:text-right text-2xl md:text-4xl font-black tabular-nums mt-2 md:mt-0 self-center ${effectColor}`}
    >
      {effectSign}{monthsGained}<span class="text-sm md:text-base font-sans ml-1">ヶ月</span>
      <span
        class="inline-block ml-3 transition group-hover:translate-x-1 text-[var(--color-sub)] text-lg md:text-xl"
        >→</span
      >
    </div>
  </div>
</a>

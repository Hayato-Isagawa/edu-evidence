---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import StrategyRow from "../../components/StrategyRow.astro";

const allStrategies = await getCollection("strategies");

const costGroups = [
  {
    level: 1,
    label: "明日から始められる",
    desc: "教師の工夫だけで可能。特別な予算不要。",
    yen: "¥",
  },
  {
    level: 2,
    label: "少しの準備で始められる",
    desc: "少額の教材費、または短時間の研修が必要。",
    yen: "¥¥",
  },
  {
    level: 3,
    label: "まとまった準備が必要",
    desc: "教材費、定期的な研修、一部人員の確保が必要。",
    yen: "¥¥¥",
  },
  {
    level: 4,
    label: "相当な投資が必要",
    desc: "専門スタッフの配置、大規模な研修が必要。",
    yen: "¥¥¥¥",
  },
  {
    level: 5,
    label: "組織的な投資が必要",
    desc: "人員増や施設変更など、制度レベルの投資。",
    yen: "¥¥¥¥¥",
  },
];
---

<Layout title="コストから探す — EduEvidence JP">
  <section class="pt-10 sm:pt-14 md:pt-20 lg:pt-28 pb-10 sm:pb-14 md:pb-20">
    <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]">
      Browse by cost
    </p>
    <h1 class="mt-5 font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl leading-[1.15] tracking-tight">
      コストから探す
    </h1>
    <div class="mt-6 max-w-2xl text-[var(--color-sub)] leading-loose text-sm sm:text-base">
      <p>「お金をかけずに明日から」始められるものから探せます。</p>
    </div>
  </section>

  <section class="pb-24 space-y-16">
    {
      costGroups.map((group) => {
        const strategies = allStrategies
          .filter((s) => s.data.cost === group.level)
          .sort((a, b) => b.data.monthsGained - a.data.monthsGained);
        if (strategies.length === 0) return null;
        return (
          <div class="space-y-4">
            <div class="space-y-2">
              <div class="flex items-baseline gap-4 px-2">
                <span class="text-xl font-black text-emerald-700 tracking-widest">{group.yen}</span>
                <h2 class="text-xl font-black tracking-tight">{group.label}</h2>
                <span class="text-xs text-[var(--color-sub)]">{strategies.length}件</span>
              </div>
              <p class="text-sm text-[var(--color-sub)] px-2">{group.desc}</p>
            </div>
            <div class="border-b border-[var(--color-line)]">
              {strategies.map((s, i) => (
                <StrategyRow
                  index={i + 1}
                  href={`/strategies/${s.id}`}
                  title={s.data.title}
                  monthsGained={s.data.monthsGained}
                  evidenceStrength={s.data.evidenceStrength}
                  evidence={s.data.evidence}
                  subjects={s.data.subjects}
                  grades={s.data.grades}
                />
              ))}
            </div>
          </div>
        );
      })
    }
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
---

<Layout title="検索 — EduEvidence JP" description="指導法・コラム・用語を検索">
  <section class="py-10 xs:py-14 sm:py-20 md:py-28 space-y-8">
    <div class="space-y-2">
      <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]">
        Search
      </p>
      <h1 class="font-black text-5xl md:text-6xl leading-[1.15] tracking-tight">
        検索
      </h1>
    </div>
    <div id="search" class="max-w-2xl"></div>
    <p id="search-fallback" class="text-sm text-[var(--color-sub)] hidden">
      検索機能はビルド後の環境で動作します。<code class="font-mono text-xs bg-[var(--color-card)] px-1.5 py-0.5 rounded">npm run build && npm run preview</code> で確認できます。
    </p>
  </section>

  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>
  <script is:inline>
    (function initPagefind(retries) {
      if (typeof PagefindUI === "undefined") {
        if (retries > 10) {
          // pagefind-ui.js が読み込めない(dev環境等)
          var fb = document.getElementById("search-fallback");
          if (fb) fb.classList.remove("hidden");
          return;
        }
        setTimeout(function() { initPagefind((retries || 0) + 1); }, 200);
        return;
      }
      var el = document.getElementById("search");
      if (!el) return;
      // 既に初期化済みならスキップ
      if (el.querySelector(".pagefind-ui")) return;
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        translations: {
          placeholder: "指導法・コラム・用語を検索...",
          zero_results: "「[SEARCH_TERM]」に一致する結果は見つかりませんでした",
          many_results: "[COUNT]件の結果が見つかりました",
          filters_label: "フィルター",
          clear_search: "クリア",
        },
      });
    })();
  </script>

  <style>
    :root {
      --pagefind-ui-scale: 0.9;
      --pagefind-ui-primary: #2b5d3a;
      --pagefind-ui-text: #1a1a1a;
      --pagefind-ui-background: #faf9f5;
      --pagefind-ui-border: #e5e3da;
      --pagefind-ui-tag: #2b5d3a;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 8px;
      --pagefind-ui-font: "Noto Sans JP", sans-serif;
    }
  </style>
</Layout>

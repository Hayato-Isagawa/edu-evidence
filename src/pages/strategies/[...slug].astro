---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const strategies = await getCollection("strategies");
  return strategies.map((s) => ({ params: { slug: s.id }, props: { entry: s } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const stars = "★".repeat(d.evidenceStrength) + "☆".repeat(5 - d.evidenceStrength);
const yen = "¥".repeat(d.cost) + "·".repeat(5 - d.cost);
const sourceLabel = d.source === "japan" ? "日本研究" : "EEF";
const sourceColor =
  d.source === "japan"
    ? "text-rose-600 border-rose-600/40"
    : "text-sky-700 border-sky-700/40";
const effectSign = d.monthsGained > 0 ? "+" : d.monthsGained === 0 ? "±" : "";
const effectColor =
  d.monthsGained > 0
    ? "text-[var(--color-accent)]"
    : d.monthsGained === 0
      ? "text-[var(--color-sub)]"
      : "text-red-600";
const effectNote =
  d.monthsGained > 0
    ? `3月時点で、通常より約${d.monthsGained}ヶ月先の学力水準に到達`
    : d.monthsGained === 0
      ? "学力への効果は確認されていない"
      : `3月時点で、通常より約${Math.abs(d.monthsGained)}ヶ月分学力が低下する傾向`;
---

<Layout title={`${d.title} — EduEvidence JP`} description={d.summary}>
  <div class="pt-10 pb-6">
    <a
      href="/"
      class="font-mono text-xs uppercase tracking-widest text-[var(--color-sub)] hover:text-[var(--color-ink)]"
    >
      ← 指導法一覧へ戻る
    </a>
  </div>

  <header class="grid grid-cols-12 gap-6 pb-12 border-b border-[var(--color-line)]">
    <div class="col-span-12 md:col-span-8 space-y-6">
      <div class="space-y-1">
        <div class="flex items-center gap-3">
          <p
            class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)] leading-none"
          >
            Strategy
          </p>
          <span
            class={`font-mono text-[10px] tracking-widest uppercase border rounded-full px-2 py-0.5 leading-none inline-flex items-center h-5 ${sourceColor}`}
          >
            {sourceLabel}
          </span>
        </div>
        <p class="text-xs text-[var(--color-sub)]">指導法</p>
      </div>
      <h1
        class="font-black text-5xl md:text-6xl leading-[1.15] tracking-tight"
      >
        {d.title}
      </h1>
      <p
        class="text-[var(--color-sub)] text-base md:text-lg leading-loose max-w-xl"
      >
        {d.summary}
      </p>
    </div>

    <div
      class="col-span-12 md:col-span-4 md:pt-2 grid grid-cols-2 md:grid-cols-1 gap-y-6 gap-x-4 font-mono text-xs"
    >
      <div class="space-y-1">
        <div class="uppercase tracking-widest text-[var(--color-sub)]">
          学習効果
        </div>
        <div
          class={`text-4xl font-black tabular-nums ${effectColor}`}
        >
          {effectSign}{d.monthsGained}<span class="text-base ml-1">ヶ月</span>
        </div>
        <div class="normal-case tracking-normal text-[var(--color-sub)] leading-snug">
          {effectNote}
        </div>
      </div>
      <div class="space-y-1">
        <div class="uppercase tracking-widest text-[var(--color-sub)]">
          エビデンス
        </div>
        <div class="text-amber-600 text-base">{stars}</div>
      </div>
      <div class="space-y-1">
        <div class="uppercase tracking-widest text-[var(--color-sub)]">
          コスト
        </div>
        <div class="text-[var(--color-accent)] text-base tracking-widest">
          {yen}
        </div>
      </div>
      <div class="space-y-1">
        <div class="uppercase tracking-widest text-[var(--color-sub)]">
          対象
        </div>
        <div class="text-[var(--color-ink)] leading-relaxed">
          {d.subjects.join(" · ")}<br />{d.grades.join(" · ")}
        </div>
      </div>
    </div>
  </header>

  <article class="prose-article py-16 max-w-2xl">
    <Content />
  </article>

  {
    d.sourceUrl && (
      <section class="pt-8 border-t border-[var(--color-line)] max-w-2xl space-y-2">
        <div class="text-xs text-[var(--color-sub)]">
          参考にしている情報源
        </div>
        <a
          class="link-underline text-[var(--color-ink)] hover:text-[var(--color-accent)]"
          href={d.sourceUrl}
          target="_blank"
          rel="noopener"
        >
          {d.sourceTitle ?? d.sourceUrl}
        </a>
      </section>
    )
  }
</Layout>

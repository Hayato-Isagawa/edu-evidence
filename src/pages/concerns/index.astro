---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { concernCategories } from "../../data/concerns";

const strategies = await getCollection("strategies");
const strategyMap = new Map(
  strategies.map((s) => [
    s.id,
    { title: s.data.title, monthsGained: s.data.monthsGained },
  ])
);

const columns = await getCollection("columns");
const columnMap = new Map(columns.map((c) => [c.id, c.data.title]));

const totalConcerns = concernCategories.reduce(
  (sum, cat) => sum + cat.concerns.length,
  0
);

function formatMonths(m: number): string {
  if (m > 0) return `+${m}ヶ月`;
  if (m < 0) return `${m}ヶ月`;
  return "±0ヶ月";
}
---

<Layout title="悩みから探す — EduEvidence JP">
  <section class="py-10 xs:py-14 sm:py-20 md:py-28 grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-8 space-y-6">
      <p
        class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]"
      >
        Find by your concern
      </p>
      <h1 class="font-black text-5xl md:text-6xl leading-[1.15] tracking-tight">
        <span class="text-[var(--color-accent)]">悩み</span>から探す
      </h1>
    </div>
    <div
      class="col-span-12 md:col-span-4 md:pt-6 text-[var(--color-sub)] leading-loose text-sm"
    >
      <p>
        現場でよくある悩みから、<br />
        エビデンスに裏付けられた<br />
        指導法・コラムに進めます。
      </p>
      <p class="text-xs mt-3">
        {concernCategories.length}カテゴリ / {totalConcerns}の悩み
      </p>
    </div>
  </section>

  <section class="pb-24 space-y-16">
    {
      concernCategories.map((cat) => (
        <div class="space-y-6">
          <div class="border-b border-[var(--color-line)] pb-3 flex items-baseline gap-4 flex-wrap">
            <h2
              id={cat.id}
              class="font-black text-2xl md:text-3xl tracking-tight"
            >
              {cat.title}
            </h2>
            <p class="text-sm text-[var(--color-sub)]">{cat.description}</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {cat.concerns.map((concern) => (
              <article class="border border-[var(--color-line)] rounded-xl p-5 md:p-6 bg-[var(--color-card)] space-y-4">
                <h3 class="font-black text-lg md:text-xl leading-snug">
                  {concern.title}
                </h3>
                <p class="text-sm text-[var(--color-sub)] leading-relaxed">
                  {concern.diagnosis}
                </p>

                <div class="space-y-2">
                  <p class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-sub)]">
                    関連する指導法
                  </p>
                  <ul class="flex flex-wrap gap-2">
                    {concern.strategies.map((slug) => {
                      const s = strategyMap.get(slug);
                      if (!s) return null;
                      return (
                        <li>
                          <a
                            href={`/strategies/${slug}`}
                            class="inline-flex items-baseline gap-1.5 border border-[var(--color-line)] rounded-full px-3 py-1 text-xs hover:border-[var(--color-accent)] hover:bg-[var(--color-bg)] transition"
                          >
                            <span class="font-bold">{s.title}</span>
                            <span class="font-mono text-[10px] text-[var(--color-sub)]">
                              {formatMonths(s.monthsGained)}
                            </span>
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>

                {concern.columns && concern.columns.length > 0 && (
                  <div class="space-y-2">
                    <p class="font-mono text-[10px] uppercase tracking-widest text-[var(--color-sub)]">
                      関連コラム
                    </p>
                    <ul class="space-y-1">
                      {concern.columns.map((slug) => {
                        const title = columnMap.get(slug);
                        if (!title) return null;
                        return (
                          <li>
                            <a
                              href={`/columns/${slug}`}
                              class="text-sm link-underline hover:text-[var(--color-accent)] transition"
                            >
                              → {title}
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                )}
              </article>
            ))}
          </div>
        </div>
      ))
    }
  </section>
</Layout>

---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const strategies = await getCollection("strategies");

const subjectMap = new Map<string, number>();
for (const s of strategies) {
  for (const subj of s.data.subjects) {
    subjectMap.set(subj, (subjectMap.get(subj) ?? 0) + 1);
  }
}

const subjects = [...subjectMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Layout title="教科から探す — EduEvidence JP">
  <section class="py-20 md:py-28 grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-8">
      <p class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)] mb-6">
        Browse by subject
      </p>
      <h1 class="font-black text-5xl md:text-6xl leading-[1.15] tracking-tight">
        教科から探す
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:pt-6 text-[var(--color-sub)] leading-loose text-sm">
      <p>担当する教科に関連する<br />指導法を見つけられます。</p>
    </div>
  </section>

  <section class="pb-24">
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {
        subjects.map(([subj, count]) => (
          <a
            href={`/subjects/${encodeURIComponent(subj)}`}
            class="group block border border-[var(--color-line)] rounded-xl p-6 hover:border-[var(--color-accent)] hover:bg-[var(--color-card)] transition"
          >
            <div class="text-2xl font-black group-hover:text-[var(--color-accent)] transition">
              {subj}
            </div>
            <div class="font-mono text-xs text-[var(--color-sub)] mt-2">
              {count} entries →
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

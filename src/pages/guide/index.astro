---
import Layout from "../../layouts/Layout.astro";

const guides = [
  {
    num: "01",
    title: "指標の読み方",
    desc: "「+◯ヶ月」「エビデンスの強さ(★)」「導入コスト(¥)」「出典バッジ」の4指標を詳しく解説。",
    href: "/guide/indicators",
  },
  {
    num: "02",
    title: "エビデンス入門",
    desc: "「エビデンスに基づく教育」とは何か。メタ分析・効果量・研究のレベル・エビデンスの限界まで。",
    href: "/guide/evidence",
  },
  {
    num: "03",
    title: "エビデンスと文化的文脈",
    desc: "海外の研究はそのまま日本に当てはまらない。本サイトの出典階層(EEF / 日本研究 / Hattie)と、日本の教育研究が限定的な理由。",
    href: "/guide/cultural-context",
  },
  {
    num: "04",
    title: "用語集",
    desc: "メタ認知、効果量、RCTなど、本サイトで使われる専門用語を一行で解説。",
    href: "/guide/glossary",
  },
];
---

<Layout title="Guide — EduEvidence JP">
  <section class="py-10 xs:py-14 sm:py-20 md:py-28 grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-8 space-y-6">
      <p
        class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]"
      >
        Guide
      </p>
      <h1
        class="font-black text-5xl md:text-6xl leading-[1.15] tracking-tight"
      >
        読み方ガイド
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:pt-6 text-[var(--color-sub)] leading-loose text-sm">
      <p>
        指導法の記事をより深く理解するための<br />
        補助資料を揃えています。
      </p>
    </div>
  </section>

  <section class="pb-24">
    <div class="border-b border-[var(--color-line)]">
      {
        guides.map((g) => (
          <a
            href={g.href}
            class="group block border-t border-[var(--color-line)] py-10 transition hover:bg-[var(--color-card)]"
          >
            <div class="grid grid-cols-12 gap-4 items-baseline px-2">
              <div class="col-span-2 md:col-span-1 font-mono text-sm text-[var(--color-sub)]">
                {g.num}
              </div>
              <div class="col-span-10 md:col-span-8 space-y-2">
                <h3 class="text-2xl md:text-3xl font-black tracking-tight leading-tight group-hover:text-[var(--color-accent)] transition">
                  {g.title}
                </h3>
                <p class="text-sm text-[var(--color-sub)] leading-relaxed">
                  {g.desc}
                </p>
              </div>
              <div class="hidden md:block md:col-span-3 text-right text-[var(--color-sub)] text-xl transition group-hover:translate-x-1">
                →
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

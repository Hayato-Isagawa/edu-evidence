---
import Layout from "../layouts/Layout.astro";

const entries = [
  {
    date: "2026-04-16",
    items: [
      {
        type: "update",
        text: "よくある質問を全面改訂。13問に拡充し、4セクション(数値の読み方/数値を鵜呑みにしないために/使い方・応用/サイト運用・ライセンス)に再構成。用語ツールチップ・内部リンク・動的効果量を追加",
      },
      {
        type: "add",
        text: "用語集に「クラスターRCT」「Visible Learning」を追加。英略語に日本語名を併記(例: RCT → RCT(ランダム化比較試験))",
      },
      {
        type: "update",
        text: "指標の読み方ガイドに Technical Appendix(研究数・サンプルサイズ・一次メタ分析・限界)を追加。5指導法で先行実装",
      },
      {
        type: "update",
        text: "セキュリティ強化: GitHub パスキー追加、Cloudflare 2FA有効化、両ドメインに DMARC レコード設定、SMS認証を削除",
      },
    ],
  },
  {
    date: "2026-04-15",
    items: [
      {
        type: "update",
        text: "指標の読み方ガイドを改善。導入コストに EEF の £ 基準と日本円換算・具体例を追加。出典バッジの説明セクション(第4指標)を追加し、「3指標」→「4指標」に統一",
      },
      {
        type: "update",
        text: "各指導法の効果量を一次研究と再照合し、本文と数値のズレを複数修正(メタ認知 +7→+8 等)",
      },
      {
        type: "update",
        text: "サイト全体のセキュリティを強化",
      },
    ],
  },
  {
    date: "2026-04-14",
    items: [
      {
        type: "add",
        text: "コラム2本追加:「給食無償化で学力は上がるのか？」「いじめ認知76万件 — 『認知が増えた』は悪いことなのか？」。コラムは計12本に",
      },
      {
        type: "add",
        text: "指導法一覧にカテゴリフィルター(指導法/認知科学/制度・環境/知っておくべき知見/家庭・外部)を追加",
      },
      {
        type: "update",
        text: "指導法タイトル10件を「1指導法=1焦点」に統一(例:「メタ認知と自己調整学習」→「メタ認知の指導」、「ブロック学習 vs 交互練習」→「ブロック学習の落とし穴」)",
      },
    ],
  },
  {
    date: "2026-04-13",
    items: [
      {
        type: "add",
        text: "コラム3本追加:「不登校35万人時代」「教員不足と授業の質」「生成AIは教育をどう変えるか」。コラムは計10本に",
      },
      {
        type: "add",
        text: "Visible Learning(Hattie)の説明をトップページの「データの出典」セクションと用語集に追加",
      },
      {
        type: "update",
        text: "専門用語ツールチップを23語→35語に拡充(ICT・PISA・OECD・検索練習・分散学習・Visible Learning 等を追加)",
      },
      {
        type: "update",
        text: "指導法タイトルを「1つの指導法＝1つの焦点」に統一。vs構造・2要素混在の10件を修正(例:「メタ認知と自己調整学習」→「メタ認知の指導」)",
      },
      {
        type: "update",
        text: "メタ認知 +7→+8ヶ月、探究学習 +7→+5ヶ月 の反映漏れを全ページで修正",
      },
      {
        type: "update",
        text: "How to Read の例を実データに整合(+5/-5の対称表示、「取り入れる価値のある指導法」の対表現を追加)",
      },
      {
        type: "update",
        text: "ページ内スムーズスクロール対応。セキュリティヘッダー(CSP・HSTS)強化。AIクローラーを許可に変更(教育エビデンスの普及目的)",
      },
      {
        type: "update",
        text: "About ページにフィンランド教育動画のリンクと関連コラムへの導線を追加",
      },
    ],
  },
  {
    date: "2026-04-12",
    items: [
      {
        type: "update",
        text: "全73指導法のエビデンスを一次研究と照合し、9件の効果量を修正。全件に出典別エビデンス(EEF / 日本研究 / Hattie)と「日本の文脈で考慮したいこと」を追加",
      },
      {
        type: "add",
        text: "指導法ページに出典バッジを複数表示(EEF・日本・Hattie の該当するものすべて)",
      },
      {
        type: "add",
        text: "専門用語ホバーツールチップ(23語対応)。本文中の用語にマウスを乗せると定義が表示される",
      },
      {
        type: "add",
        text: "トップページに「データの出典(EEF Toolkit とは)」説明セクションを追加",
      },
      {
        type: "add",
        text: "全文検索機能を導入。サイト内のすべての指導法・コラム・ガイドを横断検索できるように",
      },
      {
        type: "add",
        text: "指導法ごとの SNS 共有用画像を自動生成(タイトル・効果量・★が表示される)",
      },
      {
        type: "add",
        text: "404ページ(見つからないページ用)を追加",
      },
      {
        type: "update",
        text: "用語集を50語に拡充。コラムのテーブルスタイルを改善。アクセシビリティ改善",
      },
    ],
  },
  {
    date: "2026-04-11",
    items: [
      {
        type: "update",
        text: "スマートフォンでの表示を全面的に最適化(余白・行間・カード配置を改善)",
      },
      {
        type: "update",
        text: "スマートフォンでのナビゲーションをハンバーガーメニューに変更",
      },
      {
        type: "update",
        text: "グローバルナビを日本語に統一(ホーム / 指導法から探す / コラム / ガイド / サイトについて)。コンテンツファーストの導線に再編",
      },
      {
        type: "update",
        text: "フッターを4カラムに再構成(ブランド / 指導法を探す / 学ぶ・読む / サイトについて)。お問い合わせ先(info@edu-evidence.org)を明示",
      },
      {
        type: "update",
        text: "機能を表すラベルを日本語化(並び替え / 参考にしている情報源 / 件数表記 など)。戻るボタンを「← ◯◯一覧へ戻る」に統一",
      },
      {
        type: "add",
        text: "About ページに「サイトの公開性」サブセクションを追加。ソースコードの公開姿勢を明示",
      },
    ],
  },
  {
    date: "2026-04-10",
    items: [
      {
        type: "add",
        text: "指導法を 30 項目から 66 項目に拡充。Hattie ランキング / 認知科学 / 日本の教育研究 / デジタル学習 / 負の効果カテゴリを新設",
      },
      {
        type: "add",
        text: "政策とエビデンス(政策対照10項目)ページを新設。教育施策と研究知見を並列で確認できる",
      },
      {
        type: "add",
        text: "教科別 / 学年別 / コスト別 / タグ別の絞り込みページを実装",
      },
      {
        type: "add",
        text: "コラム「エビデンスで考える」シリーズを4本追加",
      },
      {
        type: "add",
        text: "用語集を 25 語から 28 語に拡充",
      },
      {
        type: "add",
        text: "ロゴ・favicon・OG 画像(葉っぱモチーフ)を実装",
      },
    ],
  },
  {
    date: "2026-04-09",
    items: [
      { type: "add", text: "サイト公開。指導法30項目を掲載" },
      { type: "add", text: "ガイド: 指標の読み方 / エビデンス入門 / 用語集(25語)" },
      { type: "add", text: "FAQ(10問)、Aboutページ(編集方針・監修者欄)" },
      { type: "add", text: "現場の声コーナー、更新履歴ページ、サポートページ" },
      {
        type: "add",
        text: "全30項目に参考研究(メタ分析・RCT・国内研究)を2〜3本ずつ掲載",
      },
    ],
  },
];

const typeLabel: Record<string, { label: string; color: string }> = {
  add: { label: "追加", color: "text-emerald-700" },
  update: { label: "更新", color: "text-amber-600" },
  fix: { label: "修正", color: "text-rose-600" },
  remove: { label: "削除", color: "text-[var(--color-sub)]" },
};
---

<Layout title="更新履歴 — EduEvidence JP">
  <section class="py-10 xs:py-14 sm:py-20 md:py-28 grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-8 space-y-6">
      <p
        class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]"
      >
        Changelog
      </p>
      <h1
        class="font-black text-5xl md:text-6xl leading-[1.15] tracking-tight"
      >
        更新履歴
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 md:pt-6 text-[var(--color-sub)] leading-loose text-sm">
      <p>
        記事の追加・修正・改訂を<br />
        時系列で記録しています。
      </p>
    </div>
  </section>

  <section class="pb-24">
    {
      entries.map((entry) => (
        <div class="border-t border-[var(--color-line)] py-10 space-y-4">
          <div class="font-mono text-sm text-[var(--color-accent)]">
            {entry.date}
          </div>
          <ul class="space-y-3">
            {entry.items.map((item) => {
              const t = typeLabel[item.type] ?? typeLabel.add;
              return (
                <li class="flex gap-3 items-baseline text-sm leading-relaxed">
                  <span
                    class={`font-mono text-xs uppercase tracking-widest shrink-0 ${t.color}`}
                  >
                    {t.label}
                  </span>
                  <span>{item.text}</span>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
    <div class="border-t border-[var(--color-line)]"></div>
  </section>
</Layout>
